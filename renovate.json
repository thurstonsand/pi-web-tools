{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "timezone": "America/New_York",
  "labels": ["dependencies"],
  "schedule": ["* * * * 1"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)hk\\.pkl$/"],
      "matchStrings": [
        "package://github\\.com/jdx/hk/releases/download/v(?<currentValue>[^/]+)/hk@[^#]+#/(?<depType>Config|Builtins)\\.pkl"
      ],
      "depNameTemplate": "hk",
      "packageNameTemplate": "jdx/hk",
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v(?<version>.+)",
      "autoReplaceStringTemplate": "package://github.com/jdx/hk/releases/download/v{{{newValue}}}/hk@{{{newValue}}}#/{{{depType}}}.pkl"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm packages"
    },
    {
      "matchManagers": ["mise"],
      "groupName": "mise tools"
    },
    {
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["jdx/hk"],
      "groupName": "hk",
      "groupSlug": "hk"
    }
  ]
}
